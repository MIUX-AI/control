# Core database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Security (required in production)
APP_ENCRYPTION_KEY="generate-random-32-plus-char-secret"
SESSION_SECRET="generate-separate-random-32-plus-char-secret"
ADMIN_KEY="replace-with-your-admin-access-key"

# Public base URL (recommended, especially for Freepik webhooks)
APP_BASE_URL="https://your-project.vercel.app"
FREEPIK_WEBHOOK_SECRET=""

# Vercel Blob (required if you want browser uploads on Vercel)
BLOB_READ_WRITE_TOKEN=""
# Optional for local development via ngrok if you want Blob upload completion callbacks locally
VERCEL_BLOB_CALLBACK_URL=""

# Optional cron auth for /api/internal/maintenance
CRON_SECRET=""

# Runtime tuning
SYNC_BATCH_SIZE=10
KEY_COOLDOWN_MS=300000
REQUEST_TIMEOUT_MS=120000
RESULT_URL_TTL_MS=3600000
SESSION_TTL_HOURS=12
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10

# Legacy compatibility only. Leave enabled if you already have old ciphertext in DB.
ALLOW_LEGACY_DATABASE_URL_CRYPTO=true
